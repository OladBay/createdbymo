          <path
            d="M3 13L13 3M13 3H6M13 3V10"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <!-- Cards -->
    <div class="services-grid">
      <!-- Video Editing -->
      <div class="services-card">
