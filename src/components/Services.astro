---
import "../styles/services.css";
---

<section class="services" id="services">
  <div class="services-inner">
    <!-- Header -->
    <div class="services-header">
      <h2 class="services-headline">Our Services</h2>
      <a href="#contact" class="btn-primary services-cta">
        Talk to Mo
