          </svg>
        </div>
        <h3 class="services-card-title">Video Editing</h3>
        <p class="services-card-body">
          Raw footage goes in. Something people can't stop watching comes out.
          Every cut, every transition, every second is intentional.
        </p>
      </div>

      <!-- Shorts & Reels -->
      <div class="services-card">
        <div class="services-icon">
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M7,4.5 L7,19.5 C7,20.3284271 7.67157288,21 8.5,21 L15.5113578,21 C16.3397849,21 17.0113578,20.3284271 17.0113578,19.5 L17.0113578,4.5 C17.0113578,3.67157288 16.3397849,3 15.5113578,3 L8.5,3 C7.67157288,3 7,3.67157288 7,4.5 Z M6,4.5 C6,3.11928813 7.11928813,2 8.5,2 L15.5113578,2 C16.8920696,2 18.0113578,3.11928813 18.0113578,4.5 L18.0113578,19.5 C18.0113578,20.8807119 16.8920696,22 15.5113578,22 L8.5,22 C7.11928813,22 6,20.8807119 6,19.5 L6,4.5 Z M11,19 C11,18.448 11.448,18 12,18 C12.552,18 13,18.448 13,19 C13,19.552 12.552,20 12,20 C11.448,20 11,19.552 11,19 Z"
              fill="currentColor"></path>
          </svg>
        </div>
        <h3 class="services-card-title">Shorts & Reels</h3>
        <p class="services-card-body">
          Vertical content that stops the scroll. Built for TikTok, Instagram
          Reels and YouTube Shorts with the kind of energy that makes people hit
          share.
        </p>
      </div>

      <!-- Motion Graphics -->
      <div class="services-card">
        <div class="services-icon">
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M7 21L17 21"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M13.5 7L13.5 11M13.5 13L13.5 11M13.5 11L14.8706 9.43363M17 7L14.8706 9.43363M14.8706 9.43363L17 13"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M9.5 7L6.5 11.5L10 11.5L10 13"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M2 16.4V3.6C2 3.26863 2.26863 3 2.6 3H21.4C21.7314 3 22 3.26863 22 3.6V16.4C22 16.7314 21.7314 17 21.4 17H2.6C2.26863 17 2 16.7314 2 16.4Z"
              stroke="currentColor"
              stroke-width="1.5"></path>
          </svg>
        </div>
        <h3 class="services-card-title">Motion Graphics</h3>
        <p class="services-card-body">
          Text that moves. Graphics that hit. Motion that makes your brand
          impossible to ignore.
        </p>
      </div>

      <!-- Commercial Ads -->
      <div class="services-card">
        <div class="services-icon">
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M22 10.5V12C22 16.714 22 19.0711 20.5355 20.5355C19.0711 22 16.714 22 12 22C7.28595 22 4.92893 22 3.46447 20.5355C2 19.0711 2 16.714 2 12C2 7.28595 2 4.92893 3.46447 3.46447C4.92893 2 7.28595 2 12 2H13.5"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"></path>
            <circle
              cx="19"
              cy="5"
              r="3"
              stroke="currentColor"
              stroke-width="1.5"></circle>
            <path
              d="M7 14L9.29289 11.7071C9.68342 11.3166 10.3166 11.3166 10.7071 11.7071L12.2929 13.2929C12.6834 13.6834 13.3166 13.6834 13.7071 13.2929L17 10M17 10V12.5M17 10H14.5"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h3 class="services-card-title">Commercial Ads</h3>
        <p class="services-card-body">
          Ads that don't feel like ads. The kind that make people stop, watch,
          and actually want what you're selling.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const cards = document.querySelectorAll<HTMLElement>(".services-card");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("in-view");
        }
      });
    },
    { threshold: 0.15 }
  );

  cards.forEach((card) => observer.observe(card));
</script>
