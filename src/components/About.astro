---
import "../styles/about.css";
---

<section class="about" id="about">
  <div class="about-inner">
    <!-- Left — Image -->
    <div class="about-image-col">
      <div class="about-image-wrap">
        <img
          src="/createdbymo/images/aboutmo.JPG"
          alt="Mo — Video Editor"
          class="about-image"
        />
      </div>
    </div>

    <!-- Right — Text -->
    <div class="about-text-col">
      <h2 class="about-headline">
        <em class="about-headline-accent">Great Editing</em>
        <em class="about-headline-muted">Isn't</em><br />
        <em class="about-headline-muted">Noticed.</em> It's <em
          class="about-headline-accent">Felt.</em
        >
      </h2>

      <p class="about-body">
        I don't just cut clips together. I chase the feeling. The moment where
        the music hits just right, where a single frame says everything, where
        someone watches it back and gets chills. That's what I'm after on every
        project, whether it's a 30-second reel or a full brand film.
      </p>

      <p class="about-cta-line">
        If you've got a story worth telling, I want to help you
        <em class="about-cta-accent">tell it right.</em> Use the button below to book
        a free call with me today. <strong
          >Completely free, no commitment.</strong
        >
      </p>

      <!-- Inline stats -->
      <div class="about-stats">
        <div class="about-stat">
          <span class="about-stat-number" data-value="200" data-suffix="+"
            >0+</span
          >
          <span class="about-stat-label">Projects</span>
        </div>
        <div class="about-stat-divider"></div>
        <div class="about-stat">
          <span class="about-stat-number" data-value="50" data-suffix="+"
            >0+</span
          >
          <span class="about-stat-label">Clients</span>
        </div>
        <div class="about-stat-divider"></div>
        <div class="about-stat">
          <span class="about-stat-number" data-value="15" data-suffix="+"
            >0+</span
          >
          <span class="about-stat-label">Awards</span>
        </div>
      </div>

      <a href="#contact" class="btn-primary about-cta">
        <i class="fa-solid fa-calendar"></i>
        Work With Me
      </a>
    </div>
  </div>
</section>

<script>
  // ─── Entrance animation ───────────────────────────────────
  const imageCol = document.querySelector<HTMLElement>(".about-image-col");
  const textCol = document.querySelector<HTMLElement>(".about-text-col");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          imageCol?.classList.add("in-view");
          textCol?.classList.add("in-view");
          observer.disconnect();
        }
      });
    },
    { threshold: 0.15 }
  );

  const section = document.querySelector<HTMLElement>(".about");
  if (section) observer.observe(section);

  // ─── Stats count up ───────────────────────────────────────
  const statNumbers =
    document.querySelectorAll<HTMLElement>(".about-stat-number");

  const statsObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          statNumbers.forEach((el, i) => {
            const target = parseInt(el.dataset.value || "0");
            const suffix = el.dataset.suffix || "";
            const duration = 2000;
            const step = duration / target;
            let current = 0;

            setTimeout(() => {
              const timer = setInterval(() => {
                current += 1;
                el.textContent = current + suffix;
                if (current >= target) {
                  clearInterval(timer);
                  el.textContent = target + suffix;
                }
              }, step);
            }, i * 150);
          });
          statsObserver.disconnect();
        }
      });
    },
    { threshold: 0.5 }
  );

  const stats = document.querySelector<HTMLElement>(".about-stats");
  if (stats) statsObserver.observe(stats);
</script>
